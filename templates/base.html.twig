<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="d-flex flex-column min-vh-100">
        <div class="position-relative" style="height: 25vh;">
            <video autoplay muted loop id="myVideo" class="w-100" style="height: 100%; object-fit: cover;">
                <source src="{{ asset('images/video.mp4') }}" type="video/mp4">
            </video>
            <div class="position-absolute top-50 start-50 translate-middle">
                <h1 style="color: white; font-size: 3rem; font-weight: bold;">OnlineGameStore</h1>
            </div>
        </div>
        <section class="d-flex justify-content-center position-relative" style="margin-bottom: 2rem;">
            <nav class="navbar navbar-expand-lg navbar-light bg-light w-100">
            <div class="container-fluid">
            <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav">
            <a class="navbar-brand" href="{{ path('app_home') }}" style="font-weight: 600; color: #000;">Home</a>
            <li class="nav-item">
            <a class="nav-link" href="#" style="font-weight: 600; color: #000;">Catalog</a>
            </li>
            <li class="nav-item">
            <a class="nav-link" href="#" style="font-weight: 600; color: #000;">About Us</a>
            </li>
            <li class="nav-item">
            <a class="nav-link" href="#" style="font-weight: 600; color: #000;">Contact</a>
            </li>
            </ul>
            {% if is_granted('ROLE_USER') %}
            <ul class="navbar-nav ms-auto">
            <li class="nav-item">
            <a class="nav-link" href="{{ path('app_logout') }}" style="font-weight: 600; color: #000;">Logout</a>
            </li>
            </ul>
            {% else %}
            <ul class="navbar-nav ms-auto">
            <li class="nav-item">
            <a class="nav-link" href="{{ path('app_login') }}" style="font-weight: 600; color: #000;">Login</a>
            </li>
            <li class="nav-item">
            <a class="nav-link" href="{{ path('app_register') }}" style="font-weight: 600; color: #000;">Register</a>
            </li>
            </ul>
            {% endif %}
            </div>
            </div>
            </nav>
            <div class="position-absolute top-0 start-0 w-100 h-100 d-flex justify-content-center align-items-center" style="pointer-events:none;">
            </div>
        </section>
        <div class="container">
            {% block body %}{% endblock %}
        </div>
        <footer class="bg-dark text-white text-center py-3 mt-auto">
            &copy; {{ "now"|date("Y") }} OnlineGameStore. All rights reserved.
        </footer>
        

    </body>
</html>
